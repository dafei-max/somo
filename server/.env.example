# Copy this file to .env and fill in your API keys

# LLM API (e.g. OpenAI, or any OpenAI-compatible endpoint)
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Image generation API
IMAGE_API_KEY=your_image_api_key_here
IMAGE_API_BASE=https://api.openai.com/v1
IMAGE_MODEL=dall-e-3

# Audio generation API (optional)
AUDIO_API_KEY=your_audio_api_key_here
AUDIO_API_BASE=https://api.example.com/v1

# Set to "true" to use mock data without real API calls
USE_MOCK=true

PORT=3001
